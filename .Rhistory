knitr::opts_chunk$set(echo = TRUE)
# Load package
library(dplyr)
library(ggplot2)
library(suncalc)
# Find the corresponding daylight hours for the selected dates (according to the literature) in 1979 using the suncal package
# Define location
latitude <- 43.55
longitude <- -80.22
# Your selected dates
selected_dates <- as.Date(c("1979-06-26", "1979-06-27", "1979-06-28", "1979-06-29", "1979-06-30",
"1979-07-01", "1979-07-02", "1979-07-10",
"1979-07-24", "1979-07-25", "1979-07-26", "1979-07-27", "1979-07-28",
"1979-08-13", "1979-08-14", "1979-08-15", "1979-08-16", "1979-08-17",
"1979-09-01", "1979-09-02", "1979-09-03", "1979-09-04", "1979-09-05",
"1979-09-06", "1979-09-07"))
# Calculate sunrise & sunset times
daylight_data <- getSunlightTimes(date = selected_dates, lat = latitude, lon = longitude, keep = c("sunrise", "sunset"))
# Compute daylight duration in hours
daylight_data$daylight_hours <- as.numeric(difftime(daylight_data$sunset, daylight_data$sunrise, units = "hours"))
#mean(daylight_data[19:25, 6])
# ------------------------------------------------------------------------------------------------------------------------
# Experimental data from Madder et al. (1983a), which provides diapausing rates from a field study over the summer of 1979
# -------------------------------------------------------------------------------------------------------------------------
# Data
diapause_data <- data.frame(
photoperiod = c(15.395, 15.224, 14.776, 13.986, 13.060),
diapause_rate = c(0.02, 0.31, 0.45, 0.75, 0.93)
)
# Plot
ggplot(diapause_data, aes(x = photoperiod, y = diapause_rate)) +
geom_point(color = "blue", size = 3) +
geom_line(color = "blue") +
labs(
title = "Diapause Rate vs. Photoperiod",
x = "Photoperiod (hours)",
y = "Diapause Rate"
) +
theme_bw()
# ------------------------------------------------------------------------------------------------------------------------
# Now I will fit a logistic curve to the data
# diapause_rate = 1 / (1 + exp(-k * (photoperiod - m)))
# photoperiod = input variable (x-axis)
#diapause_rate = output variable (y-axis)
#k = steepness (slope)
#m = midpoint where the curve transitions
# -------------------------------------------------------------------------------------------------------------------------
# Fit logistic curve
fit <- nls(diapause_rate ~ 1 / (1 + exp(-k * (photoperiod - m))),
data = diapause_data,
start = list(k = -5, m = 14.5))  # Negative k for decreasing curve
# Summary of the fitted model
summary(fit)
# Visualize plot
ggplot(diapause_data, aes(x = photoperiod, y = diapause_rate)) +
geom_point(color = "red", size = 3) +
geom_line(aes(y = predict(fit)), color = "blue") +
labs(title = "Diapause Rate vs. Photoperiod",
x = "Daylight Hours",
y = "Diapause Rate") +
theme_minimal()
# Plot actual data with estimated logistic curve
# Define photoperiod sequence
photoperiod <- seq(10, 20, length.out = 100)
# Observed data
field_data <- data.frame(
photoperiod = c(15.395, 15.224, 14.776, 13.986, 13.060),
diapause_rate = c(0.02, 0.31, 0.45, 0.75, 0.93)
)
# Logistic curve using estimated parameters
k <- -2.0285
m <- 14.5955
logistic_curve <- data.frame(
photoperiod = photoperiod,
diapause_rate = 1 / (1 + exp(-k * (photoperiod - m)))
)
# Plotting
ggplot() +
geom_point(data = field_data, aes(x = photoperiod, y = diapause_rate),
color = "red", size = 2) +
geom_line(data = logistic_curve, aes(x = photoperiod, y = diapause_rate),
color = "darkblue", size = 1) +
labs(title = "Diapause Rate as a function of Photoperiod",
x = "Daylight Hours",
y = "Diapause Rate") +
theme_bw()
# The function to be used to solve the model is
#delta = 1 / (1 + exp(-(-2.0285) * (F - 14.5955)))
library(ggplot2)
# Define the sigmoid function for diapause activation
diapause_sigmoid <- function(P) {
1 / (1 + exp(-(-2.0285) * (P - 14.5955)))
}
# Define the step function for diapause activation
diapause_step <- function(P) {
ifelse(P >= 14.5955, 1, 0)
}
# Generate a sequence of photoperiod values
P_vals <- seq(12, 17, length.out = 100)
# Compute diapause activation values using both functions
sigmoid_values <- sapply(P_vals, diapause_sigmoid)
step_values <- sapply(P_vals, diapause_step)
data <- data.frame(Photoperiod = P_vals,
Sigmoid = sigmoid_values,
Stepwise = step_values)
# Plot the functions
plot <- ggplot(data, aes(x = Photoperiod)) +
geom_line(aes(y = Sigmoid), color = "blue", size = 1.2) +
geom_line(aes(y = Stepwise), color = "red", size = 1.2, linetype = "dashed") +
labs(title = "Sigmoid and Stepwise Functions for Diapause Activation",
x = "Photoperiod (hours)",
y = "Diapause Activation Rate") +
theme_minimal() +
annotate("text", x = 16, y = 0.8, label = "Sigmoid", color = "blue", size = 5, fontface = "italic") +
annotate("text", x = 16, y = 0.6, label = "Stepwise", color = "red", size = 5, fontface = "italic")
print(plot)
ggsave("diapause_plot.png", plot = plot, width = 6, height = 4, dpi = 300)
# Plotting - Cleaning figure for manuscript
ggplot() +
geom_point(data = field_data, aes(x = photoperiod, y = diapause_rate),
color = "red", size = 2) +
geom_line(data = logistic_curve, aes(x = photoperiod, y = diapause_rate),
color = "darkblue", size = 1) +
labs(title = "Diapause Rate as a function of Photoperiod",
x = "Daylight Hours",
y = "Diapause Rate") +
theme_bw() +
theme(
plot.title = element_text(face = "bold", hjust = 0.5, size = 16),
axis.text.x = element_text(angle = 0, hjust = 0.5, size = 16),
axis.title = element_text(size = 16),
axis.text.y = element_text(size = 14),
legend.position = "none"
)
